{
  "name": "S3 Backup",
  "version": "0.0.5",
  "slug": "s3-backup",
  "description": "Comprehensive S3 backup solution with modern web interface for managing Home Assistant backups",
  "url": "https://github.com/geraldhansen/homeassistant-addons/tree/main/s3-backup",
  "arch": [
    "aarch64",
    "amd64",
    "armhf",
    "armv7",
    "i386"
  ],
  "boot": "manual",
  "init": false,
  "startup": "once",
  "advanced": true,
  "hassio_api": true,
  "hassio_role": "backup",
  "ingress": true,
  "panel_icon": "mdi:pail",
  "panel_title": "S3 Backups",
  "webui": "http://[HOST]:[PORT:8099]",
  "options": {
    "aws_access_key_id": "",
    "aws_secret_access_key": "",
    "bucket_name": "",
    "endpoint_url": "",
    "bucket_region": "us-east-1",
    "storage_class": "STANDARD",
    "delete_local_backups": true,
    "local_backups_to_keep": 4
  },
  "schema": {
    "aws_access_key_id": "str",
    "aws_secret_access_key": "password",
    "bucket_name": "str",
    "endpoint_url": "str?",
    "bucket_region": "str?",
    "storage_class": "list(STANDARD|STANDARD_IA|GLACIER|DEEP_ARCHIVE)?",
    "delete_local_backups": "bool",
    "local_backups_to_keep": "int(1,50)"
  },
  "map": [
    "backup:rw"
  ]
}